@page
@model PM.Web.Pages.IndexModel
@{
    ViewData["Title"] = string.Empty;
    var content = Model.Site;
    var years = Model.YearsExperience;
    var currentYear = content.About.StartYear + years;
}
<style type="text/css">
    .skills-list {
        list-style-type: none;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(min(100%, 370px), 1fr));
        gap: 20px 30px;
        margin: 0;
        padding: 0;
        width: 100%;
    }

    .skills-list-item {
        text-align: left;
        min-width: 0;
        padding: 0 15px;
    }

    .skills-list-item.progress {
        margin: 0;
        overflow: visible;
    }
</style>
<section id="about" class="about">
    <div class="container" data-aos="fade-up">
        <div class="section-title">
            <h2>About</h2>
            <p>
                I am an experienced Engineering Leader and Software Engineer with a demonstrated history over more than @years years of professional experience. You use my software every day! Contributed to significant value add leading to an acquisition, twice. Key software engineer and director on award winning mobile POS and payments solution. What should we make for award #3?
            </p>
        </div>

        <div class="row">
            <div class="col-lg-4 text-center">
                <img src="~/img/pat.jpg" class="img-fluid" alt="">
            </div>
            <div class="col-lg-8 pt-4 pt-lg-0 content">
                <h3>@content.About.Title</h3>
                @foreach (var paragraph in content.About.Paragraphs)
                {
                    <p class="font-italic">@paragraph</p>
                }
                <div class="row">
                    <div class="col-lg-12">
                        <ul>
                            @foreach (var certification in content.About.Certifications)
                            {
                                <li><i class="fas fa-check"></i> @certification</li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="facts" class="facts">
    <div class="container" data-aos="fade-up">
        <div class="section-title">
            <h2>Facts</h2>
            <p>Some numbers from my career to-date.</p>
        </div>

        <div class="facts-content">
            <div class="fact-card">
                <div class="count-box">
                    <i class="fas fa-users"></i>
                    <span id="counter-up-years" data-num="@years"></span>
                    <p>Years Experience</p>
                </div>
            </div>
            @foreach (var fact in content.Facts)
            {
                <div class="fact-card">
                    <div class="count-box">
                        <i class="@fact.Icon"></i>
                        <span id="counter-up-@fact.Label.Replace(" ", "").ToLowerInvariant()" data-num="@fact.Value" data-duration-ms="@(fact.DurationSeconds * 1000)"></span>
                        <p>@fact.Label</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<section id="skills" class="skills section-bg">
    <div class="container" data-aos="fade-up">
        <div class="section-title">
            <h2>Key Technologies</h2>
            <p>I've worked with an assortment of technologies, frameworks and services over the years.</p>
        </div>

        <div class="row skills-content">
            <ul class="skills-list">
                @foreach (var skill in content.Skills)
                {
                    var skillYears = Math.Max(0, currentYear - skill.StartYear);
                    <li class="skills-list-item progress">
                        <span class="skill"><i class="@skill.Icon"></i> @skill.Name <span class="val">@skillYears Yrs</span></span>
                        <div class="progress-bar-wrap">
                            <div class="progress-bar" role="progressbar" aria-valuenow="@skillYears" aria-valuemin="0" aria-valuemax="@years"></div>
                        </div>
                    </li>
                }
            </ul>
        </div>
    </div>
</section>

<section id="resume" class="resume">
    <div class="container" data-aos="fade-up">
        <div class="section-title">
            <h2>Resume</h2>
            <p>The most complete and up-to-date source for my career history is on <a class="linkedin" href="https://www.linkedin.com/in/patmacmannis/" target="_blank" rel="noopener noreferrer"><i class="fab fa-linkedin"></i> LinkedIn</a>.</p>
        </div>

        <div class="row">
            <div class="col-lg-10 offset-lg-1">
                <h3 class="resume-title">Summary</h3>
                <div class="resume-item pb-0">
                    <h4>@content.Hero.Name</h4>
                    @{
                        var summaryLine = content.Resume.Summary.Replace("{years}", years.ToString(System.Globalization.CultureInfo.InvariantCulture), StringComparison.Ordinal);
                    }
                    <p><em>@summaryLine</em></p>
                    @if (content.Resume.SpeakingEngagements.Bullets.Length > 0)
                    {
                        <p><em>@content.Resume.SpeakingEngagements.Description</em></p>
                        <ul>
                            @foreach (var engagement in content.Resume.SpeakingEngagements.Bullets)
                            {
                                <li>@engagement</li>
                            }
                        </ul>
                    }
                </div>

                <h3 class="resume-title">Education</h3>
                <div class="resume-item">
                    <h4>@content.Resume.Education.Major</h4>
                    @if (!string.IsNullOrWhiteSpace(content.Resume.Education.MinorOrCertificate))
                    {
                        <h4>@content.Resume.Education.MinorOrCertificate</h4>
                    }
                    <h5>@content.Resume.Education.Period</h5>
                    <p><em>@content.Resume.Education.Location</em></p>
                </div>

                <h3 class="resume-title">Professional Experience</h3>
                @foreach (var experience in content.Resume.Experience)
                {
                    <div class="resume-item resume-item-experience">
                        <h4>@experience.Title</h4>
                        <h5>@experience.Period</h5>
                        <p><em>@experience.Org, @experience.Location</em></p>
                        @if (!string.IsNullOrWhiteSpace(experience.Subtitle))
                        {
                            <p class="resume-item-subtitle">@experience.Subtitle</p>
                        }
                        <ul>
                            @foreach (var bullet in experience.Bullets)
                            {
                                <li>@bullet</li>
                            }
                        </ul>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<section id="portfolio" class="portfolio section-bg">
    <div class="container" data-aos="fade-up">
        <div class="section-title">
            <h2>Portfolio</h2>
            <p>Here are just a handful of the projects I have worked on.</p>
        </div>

        <div class="row">
            <div class="col-lg-12 d-flex justify-content-center" data-aos="fade-up" data-aos-delay="100">
                <ul id="portfolio-filters">
                    <li data-filter="*" class="filter-active">All</li>
                    <li data-filter=".filter-web">Web Development</li>
                    <li data-filter=".filter-app">Application Upgrade</li>
                    <li data-filter=".filter-db">Database Development</li>
                </ul>
            </div>
        </div>

        <div class="row portfolio-container" data-aos="fade-up" data-aos-delay="200">
            @foreach (var project in content.Portfolio)
            {
                var filterClass = project.Category switch
                {
                    "Web Development" => "filter-web",
                    "Application Upgrade" => "filter-app",
                    "Database Development" => "filter-db",
                    _ => "filter-web",
                };
                <div class="col-lg-4 col-md-6 portfolio-item @filterClass">
                    <div class="portfolio-wrap">
                        <img src="@project.Thumbnail.Uri" class="img-fluid" alt="@project.Thumbnail.Alt" />
                        <div class="portfolio-info">
                            <h4>@project.Title</h4>
                            <p>@project.Category</p>
                            <div class="portfolio-links">
                                <a href="@project.Images[0].Uri" data-lightbox title="@project.Title"><i class="fas fa-plus"></i></a>
                                <a href="/PortfolioDetails/@project.Slug" title="Portfolio Details"><i class="fas fa-link"></i></a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<section id="services" class="services">
    <div class="container" data-aos="fade-up">
        <div class="section-title">
            <h2>Services</h2>
            <p>Here are just a few of the services I offer.</p>
        </div>

        <div class="row">
            @foreach (var service in content.Services)
            {
                <div class="col-lg-3 col-md-6 d-flex align-items-stretch" data-aos="zoom-in" data-aos-delay="100">
                    <div class="icon-box @service.ColorClass">
                        <div class="icon">
                            @Html.Raw(ServiceIconBlob(service.ColorClass))
                            <i class="@service.Icon"></i>
                        </div>
                        <h4><a href="">@service.Title</a></h4>
                        <p>@service.Description</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

