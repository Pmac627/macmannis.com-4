<section id="testimonials" class="testimonials section-bg">
    <div class="container" data-aos="fade-up">
        <div class="section-title">
            <h2>Testimonials</h2>
        </div>

        <div class="carousel testimonials-carousel" data-aos="zoom-in" data-aos-delay="100" data-autoplay="10000">
            <div class="carousel-track">
                @foreach (var testimonial in content.Testimonials)
                {
                    <div class="carousel-slide testimonial-item">
                        <h3>@testimonial.Name</h3>
                        <h4>@testimonial.Role</h4>
                        <p>
                            <i class="fas fa-quote-left quote-icon-left"></i>
                            @testimonial.Quote
                            <i class="fas fa-quote-right quote-icon-right"></i>
                        </p>
                    </div>
                }
            </div>
            <div class="carousel-dots"></div>
        </div>
    </div>
</section>
